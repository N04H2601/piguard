# Optional app-level bootstrap values
# Leave admin credentials untouched to use the web first-run wizard.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Optional. Leave empty to disable cross-origin browser access entirely.
CORS_ORIGINS=

# Trust proxy only for local/private reverse proxies by default.
TRUST_PROXY=loopback, linklocal, uniquelocal
PIGUARD_HOST_INTEGRATIONS=0

# Optional. Leave empty to let PiGuard persist a stable secret in SQLite.
JWT_SECRET=
JWT_EXPIRY=24h
PORT=3333
NODE_ENV=production
LOG_LEVEL=info

# Cookie Secure flag: "auto" detects from request protocol, "true" forces
# Secure (HTTPS only), "false" allows HTTP. Use "auto" for most setups.
COOKIE_SECURE=auto
DB_PATH=./data/piguard.db
GEOIP_PATH=./data/geoip/GeoLite2-Country.mmdb

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional SMTP defaults for advanced/custom setups
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
SMTP_TLS=true

# Nginx container name for reverse proxy monitoring (optional, default: nginx)
NGINX_CONTAINER_NAME=nginx

# OpenAI assistant (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
