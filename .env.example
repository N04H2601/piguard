# Optional app-level bootstrap values
# Leave admin credentials untouched to use the web first-run wizard.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Optional. Leave empty to reflect the browser origin dynamically.
CORS_ORIGINS=

# Optional
JWT_SECRET=
JWT_EXPIRY=24h
PORT=3333
NODE_ENV=production
LOG_LEVEL=info

# Cookie Secure flag: "auto" detects from request protocol, "true" forces
# Secure (HTTPS only), "false" allows HTTP. Use "auto" for most setups.
COOKIE_SECURE=auto
DB_PATH=./data/piguard.db
GEOIP_PATH=./data/geoip/GeoLite2-Country.mmdb

# Notifications (optional)
NTFY_URL=
NTFY_TOPIC=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Nginx container name for reverse proxy monitoring (optional, default: nginx)
NGINX_CONTAINER_NAME=nginx

# Health checks seeded on first boot (JSON array)
DEFAULT_HEALTH_CHECKS=[{"name":"Main Site","type":"http","target":"https://example.com","interval_s":60},{"name":"Dashboard API","type":"http","target":"https://status.example.com/api/v1/health","interval_s":60}]

# OpenAI assistant (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
